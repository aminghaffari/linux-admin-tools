#!/bin/bash

BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"

source "$BASE_DIR/lib/colors.sh"
source "$BASE_DIR/lib/printer.sh"
source "$BASE_DIR/lib/helpers.sh"
source "$BASE_DIR/lib/system.sh"

title "SYSTEM HEALTH"

section "System Information"
kv "Hostname" "$(hostname_short)"
kv "Operating System" "$(os_name)"
kv "Kernel" "$(kernel_version)"
kv "Date" "$(timestamp)"

section "CPU & Load"
kv "CPU Cores" "$(cpu_cores)"
kv "Load Average" "$(load_average)"
kv "Uptime" "$(uptime_pretty)"

section "Memory"
kv "Total Memory" "$(memory_total)"
kv "Used Memory" "$(memory_used)"
kv "Available Memory" "$(memory_available)"
kv "Swap Total" "$(swap_total)"
kv "Swap Used" "$(swap_used)"

section "Disk Usage"
disk_usage | while read -r fs usage mount; do
    printf "%-25s %-8s %s\n" "$fs" "$usage" "$mount"
done

section "Top CPU Process"
top_cpu_process | while read -r pid user cpu mem etime cmd; do
    kv "PID" "$pid"
    kv "User" "$user"
    kv "CPU Usage" "${cpu}%"
    kv "Memory Usage" "${mem}%"
    kv "Running Time" "$etime"
    kv "Command" "$cmd"
done

section "Top Memory Process"
top_memory_process | while read -r pid user mem cpu etime cmd; do
    kv "PID" "$pid"
    kv "User" "$user"
    kv "Memory Usage" "${mem}%"
    kv "CPU Usage" "${cpu}%"
    kv "Running Time" "$etime"
    kv "Command" "$cmd"
done

section "Failed Services"
services=$(failed_services)
if [ -z "$services" ]; then
    ok "No failed services"
else
    echo "$services"
fi

section "Health Summary"
health=0

mem=$(memory_usage_percent)
disk=$(highest_disk_usage)
load=$(load_average_1m)
cores=$(cpu_cores)

if (( mem < 80 )); then ok "Memory usage (${mem}%)"; else warn "Memory usage (${mem}%)"; ((health++)); fi
if (( disk < 80 )); then ok "Disk usage (${disk}%)"; else warn "Disk usage (${disk}%)"; ((health++)); fi

if awk "BEGIN {exit !($load < $cores)}"; then
    ok "CPU Load (${load})"
else
    warn "CPU Load (${load})"
    ((health++))
fi

if [ -z "$(failed_services)" ]; then ok "System services"; else fail "Failed services detected"; ((health++)); fi

if [ "$(swap_used)" = "0B" ]; then ok "Swap usage"; else warn "Swap is being used ($(swap_used))"; fi

echo
if [ "$health" -eq 0 ]; then
    echo -e "${GREEN}${BOLD}Overall Status : HEALTHY${RESET}"
else
    echo -e "${YELLOW}${BOLD}Overall Status : ATTENTION REQUIRED${RESET}"
fi
